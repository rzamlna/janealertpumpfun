# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: only this user can use admin commands like /status
OWNER_TELEGRAM_ID=

# Poll interval in ms (scan interval)
POLL_INTERVAL_MS=30000

# Helius (required)
HELIUS_API_KEY=
# Optional full URL override:
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# pump.fun program id (default set)
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
HELIUS_SIGNATURES_LIMIT=25
MILESTONES=2,3,5

# Filters
MAX_AGE_MINUTES=45
MIN_LIQUIDITY_USD=10000
MIN_MCAP_USD=20000
MAX_MCAP_USD=150000
MIN_BUY_SELL_RATIO=1.2
MIN_VOLUME_24H_USD=100000
CHAIN_ID=solana

# Message when user sends /start
START_ALERT_TEXT=🚨 Alert aktif! Kamu sudah subscribe alert token. Ketik /stop untuk berhenti.

# Local state file (subscribers + caches)
STATE_FILE=./state.json
